APP_NAME="Dokploy Laravel Smoke Test"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://laravel-smoke-test.<server-ip-dashed>.traefik.me

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

LOG_CHANNEL=stderr
LOG_LEVEL=info

DB_CONNECTION=mysql
DB_HOST=mariadb-shared-xxxxxx
DB_PORT=3306
DB_DATABASE=laravel_smoke_test
DB_USERNAME=laravel_smoke_test_user
DB_PASSWORD=

SESSION_DRIVER=database
CACHE_STORE=database
QUEUE_CONNECTION=database

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
MAIL_MAILER=log
SMOKE_ADMIN_PASSWORD=DokployTest123!

# Keep false for normal deploys. Temporarily set true only for an intentional
# one-time smoke-test migration/seed run, then set it back to false and redeploy.
DOKPLOY_RUN_DEPLOY_TASKS=false
